# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# App URL used in auth redirects (production)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# E2E tests (server-side only — never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
E2E_USER_PASSWORD=TestPass123!

# Optional: after migration 00049, promote yourself in SQL:
# update public.profiles set app_role = 'master' where email = 'you@example.com';


# Optional Playwright overrides
# PLAYWRIGHT_BASE_URL=http://localhost:3000
# PLAYWRIGHT_SKIP_WEBSERVER=1
